---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				padding: 0;
			}
			.hero-image {
				width: 800px;
				max-width: calc(100% - 2em);
				margin: 2em auto 0;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				border-radius: 4px;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em 4em;
			}
			.title {
				margin-bottom: 1em;
				padding: 1.5em 0 1em;
				text-align: center;
				line-height: 1.15;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
		<style is:global>
			.prose .title h1 {
				text-wrap: balance;
			}
			.prose .title .date {
				font-family: var(--font-mono);
				font-size: 0.78rem;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: var(--ink-muted);
				margin-bottom: 0.75em;
			}
			.prose .title hr {
				width: 60px;
				margin: 1.25em auto 0;
			}
			.prose h2 {
				margin-top: 3.5em;
				margin-bottom: 0.75em;
				padding-top: 1.25em;
				border-top: 1px solid var(--rule);
			}
			.prose h2:first-of-type {
				margin-top: 1.5em;
			}
			.prose h3 {
				margin-top: 2.25em;
				margin-bottom: 0.4em;
			}
			.prose h4 {
				margin-top: 1.75em;
				margin-bottom: 0.35em;
			}
			.prose hr {
				margin: 2.5em 0;
			}
			.prose .family-figure {
				margin: 2em auto;
				text-align: center;
			}
			.prose .family-figure svg {
				max-width: 100%;
				height: auto;
				background: rgba(255, 255, 255, 0.55);
				border: 1px solid var(--rule);
				border-radius: 4px;
				padding: 0.75em;
				box-sizing: border-box;
			}
			.prose .family-figure figcaption {
				margin-top: 0.75em;
				font-style: italic;
				font-size: 0.92em;
				color: var(--ink-muted);
				text-wrap: balance;
				max-width: 540px;
				margin-left: auto;
				margin-right: auto;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{
					heroImage && (
						<div class="hero-image">
							<img
								src={heroImage}
								alt={`Cover image for ${title}`}
								width="1200"
								height="630"
								loading="eager"
							/>
						</div>
					)
				}
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						{!heroImage && <h1>{title}</h1>}
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
