---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writing — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="blog-list">
			<h1 class="label">Writing</h1>
			<ol class="entries">
				{
					posts.map((post, i) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<span class="num">{String(posts.length - i).padStart(2, '0')}</span>
								<span class="title">{post.data.title}</span>
								<span class="date">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</a>
						</li>
					))
				}
			</ol>
		</main>
		<Footer />
	</body>
</html>

<style>
	.blog-list {
		width: 720px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 4rem 1em;
	}
	.label {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--ink-muted);
		margin: 0 0 2rem;
	}
	.entries {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.entries a {
		display: grid;
		grid-template-columns: 2.25rem 1fr auto;
		align-items: baseline;
		gap: 1rem;
		padding: 1rem 0;
		text-decoration: none;
		border-bottom: 1px solid var(--rule-soft);
		color: var(--ink);
	}
	.entries li:last-child a {
		border-bottom: none;
	}
	.entries .num,
	.entries .date {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		font-variant-numeric: tabular-nums;
	}
	.entries .num {
		color: var(--ink-faint);
	}
	.entries .date {
		color: var(--ink-muted);
	}
	.entries .title {
		font-size: 1.05rem;
	}
	.entries a:hover .title {
		color: var(--carmine-dark);
	}
	@media (max-width: 640px) {
		.blog-list {
			padding: 3rem 1em;
		}
		.entries a {
			grid-template-columns: 1.75rem 1fr;
			grid-template-rows: auto auto;
			gap: 0.25rem 1rem;
		}
		.entries .date {
			grid-column: 2 / 3;
		}
	}
</style>
