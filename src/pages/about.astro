---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const title = `About — ${SITE_TITLE}`;
const description = 'About John P Warren — engineer working on AI systems.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main class="about">
			<h1 class="label">About</h1>
			<section class="bio">
				<p class="lede">
					I'm John. I work on AI systems — the practical engineering
					underneath model behavior: evaluation, tool use, agent loops, the
					places where probability meets production code.
				</p>
				<p>
					This site is where I write about what I'm building. The posts so far
					are deep dives on <a href="/blog/three-roads-to-the-same-harness/"
						>Anchor</a
					> (a coordination methodology for multi-role agent work) and <a
						href="/blog/deploysignal/">DeploySignal</a
					> (a statistical deploy-gate engine for AI inference workloads). Tessera
					is next.
				</p>
				<p>
					The fastest way to reach me is through the <a
						href="https://github.com/johnpatrickwarren-oss"
						target="_blank"
						rel="noopener">GitHub</a
					> linked in the header.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.about {
		width: 640px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 4rem 1em;
	}
	.label {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--ink-muted);
		margin: 0 0 2rem;
	}
	.bio {
		font-size: 1.05rem;
		line-height: 1.65;
	}
	.lede {
		font-size: 1.35rem;
		line-height: 1.45;
		margin: 0 0 1.25em;
		text-wrap: balance;
	}
	@media (max-width: 640px) {
		.about {
			padding: 3rem 1em;
		}
		.lede {
			font-size: 1.2rem;
		}
	}
</style>
